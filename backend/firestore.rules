rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is an editor or admin
    function isEditorOrAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor');
    }
    
    // QR Codes collection rules
    match /qrCodes/{qrId} {
      // Anyone can read QR codes (for scanning purposes)
      allow read: if true;
      
      // Only authenticated users can create new QR codes
      allow create: if isAuthenticated();
      
      // Only editors or admins can update QR codes
      allow update: if isEditorOrAdmin();
      
      // Only admins can delete QR codes
      allow delete: if isAdmin();
    }
    
    // URLs collection rules
    match /urls/{urlId} {
      // Anyone can read URLs (for redirection service)
      allow read: if true;
      
      // Only authenticated users can create URLs
      allow create: if isAuthenticated();
      
      // Only editors or admins can update URLs
      allow update: if isEditorOrAdmin();
      
      // Only admins can delete URLs
      allow delete: if isAdmin();
    }
    
    // Scans collection rules
    match /scans/{scanId} {
      // Only authenticated users can read scan data
      allow read: if isAuthenticated();
      
      // Anyone can record a scan (public can create scan records)
      allow create: if true;
      
      // No updates allowed to scan records
      allow update: if false;
      
      // Only admins can delete scan records
      allow delete: if isAdmin();
    }
    
    // Users collection rules
    match /users/{userId} {
      // Users can read their own data, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can create user records
      allow create: if isAdmin();
      
      // Users can update their own basic info, admins can update all fields
      allow update: if isAuthenticated() && 
        ((request.auth.uid == userId && 
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'email', 'photoURL', 'lastLogin'])) 
        || isAdmin());
      
      // Only admins can delete user records
      allow delete: if isAdmin();
    }
  }
}